# Apache Maven Wrapper startup script, version 3.3.2
set -e

MAVEN_PROJECTBASEDIR=$(cd "$(dirname "$0")" && pwd)
WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"

# Download the wrapper JAR if it is absent (first checkout on a new machine).
if [ ! -f "$WRAPPER_JAR" ]; then
  if [ -f "$WRAPPER_PROPERTIES" ]; then
    WRAPPER_URL=$(grep -E "^wrapperUrl=" "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  fi
  if [ -z "$WRAPPER_URL" ]; then
    WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  fi
  echo "Downloading Maven wrapper JAR from $WRAPPER_URL"
  if command -v curl > /dev/null 2>&1; then
    curl -fsSL -o "$WRAPPER_JAR" "$WRAPPER_URL"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "$WRAPPER_JAR" "$WRAPPER_URL"
  else
    echo "ERROR: Neither curl nor wget found. Cannot download Maven wrapper." >&2
    exit 1
  fi
fi

# The wrapper JAR handles downloading + caching Maven itself (distributionUrl)
# and invokes it with the original arguments.
# Note: uses -cp, NOT -jar — maven-wrapper.jar has no Main-Class manifest entry.
exec java \
  -cp "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
